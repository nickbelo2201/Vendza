{
  "name": "@vendza/web-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "node -e \"try { require('node:fs').rmSync('.next', { recursive: true, force: true }) } catch(e) { console.warn('limpar .next:', e.message) }\" && next build",
    "start": "next start --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
