# ─── Banco de Dados (Obrigatório para Prisma Migrate) ────────────────────────────────
# DATABASE_URL: URL de conexão ao banco PostgreSQL (com pooling para desenvolvimento).
# DIRECT_URL: URL direta sem pooling (necessária para Prisma Migrate em produção).
# Documentação: https://www.prisma.io/docs/orm/overview/databases/postgresql
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vendza?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vendza?schema=public
REDIS_URL=redis://localhost:6379

# ─── Migrations (Prisma Migrate) ──────────────────────────────────────────────────────
# Primeiro deploy em produção:
#   1. Configure DATABASE_URL e DIRECT_URL apontando para o novo banco PostgreSQL
#   2. Execute: corepack pnpm db:migrate (a partir do diretório app/)
# Para desenvolvimento local:
#   1. Configure DATABASE_URL apontando para seu banco local
#   2. Execute: corepack pnpm db:migrate:dev (cria/atualiza migrations automaticamente)
# Documentação: https://www.prisma.io/docs/orm/prisma-migrate/workflows/team-development

# ─── Supabase (Obrigatório) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PARTNER_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3333
PAYMENT_PROVIDER=mercado_pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
WHATSAPP_DEFAULT_PHONE=5511999999999
# ─── WhatsApp via Z-API ────────────────────────────────────────────────────────
# Docs: https://developer.z-api.io/
ZAPI_INSTANCE_ID=seu_instance_id_aqui
ZAPI_TOKEN=seu_token_aqui
ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_WEBHOOK_SECRET=

# ─── IA — OpenRouter ──────────────────────────────────────────────────────────
# Docs: https://openrouter.ai/docs
OPENROUTER_API_KEY=sua_chave_aqui
AI_MODEL=google/gemini-2.0-flash

# URL pública da API (para registro automático do webhook Telegram no startup)
API_PUBLIC_URL=https://vendza-production.up.railway.app
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
STORE_SLUG=adega

# ─── Segurança: Criptografia de dados financeiros (Obrigatório) ──────────────
# OBRIGATÓRIO: PIX_ENCRYPTION_KEY é uma chave secreta usada para encriptar dados PIX.
# Deve ser uma string aleatória com pelo menos 32 caracteres.
# Será derivada para exatamente 32 bytes via SHA-256.
# Exemplo: openssl rand -base64 32
PIX_ENCRYPTION_KEY=sua_chave_secreta_aleatoria_de_ao_menos_32_caracteres_aqui

# ─── Configuração do Seed ──────────────────────────────────────────────────────
# Para criar/linkar a loja da adega ao seu usuário real do Supabase,
# preencha as variáveis abaixo e rode: corepack pnpm db:seed
#
# Como pegar o SEED_OWNER_AUTH_USER_ID:
#   1. Crie sua conta em web-partner/cadastro
#   2. Acesse Supabase Dashboard → Authentication → Users → copie o UUID
#      OU: no Supabase, rode: SELECT id FROM auth.users WHERE email = 'seu@email.com';
SEED_STORE_SLUG=adega
SEED_STORE_NAME=Adega Central
SEED_STORE_WHATSAPP=5511999999999
SEED_OWNER_AUTH_USER_ID=9f6d2e72-6d29-45e8-b6ff-9e9fa0000001
SEED_OWNER_EMAIL=owner@adega.com
SEED_OWNER_NAME=Dono da Adega
