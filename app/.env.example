# =============================================================
# Vendza V1 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# =============================================================

# ── Servidor API ──────────────────────────────────────────────
NODE_ENV=development              # OPTIONAL  (default: development)
API_HOST=0.0.0.0                  # OPTIONAL  (default: 0.0.0.0)
API_PORT=3333                     # OPTIONAL  (default: 3333)

# ── Banco de Dados (Supabase PostgreSQL) ──────────────────────
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:5432/postgres?schema=public  # REQUIRED
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:5432/postgres?schema=public    # REQUIRED

# ── Auth Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co  # REQUIRED
SUPABASE_ANON_KEY=                               # REQUIRED
SUPABASE_SERVICE_ROLE_KEY=                       # REQUIRED

# ── Storefront (qual loja servir) ─────────────────────────────
STORE_SLUG=vendza                 # REQUIRED  (slug da Store no banco)

# ── Frontends (web-client e web-partner) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co  # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=                               # REQUIRED
NEXT_PUBLIC_API_URL=http://localhost:3333                    # REQUIRED
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000                 # OPTIONAL (CORS Socket.io)
NEXT_PUBLIC_PARTNER_URL=http://localhost:3001                # OPTIONAL (CORS Socket.io)

# ── Redis + BullMQ (filas de jobs) ────────────────────────────
REDIS_URL=redis://localhost:6379  # OPTIONAL  (filas desabilitadas se ausente)

# ── Integrações V2 (não necessárias no V1) ────────────────────
PAYMENT_PROVIDER=mercado_pago     # OPTIONAL  (V2)
MERCADO_PAGO_ACCESS_TOKEN=        # OPTIONAL  (V2)
MERCADO_PAGO_PUBLIC_KEY=          # OPTIONAL  (V2)
WHATSAPP_DEFAULT_PHONE=           # OPTIONAL  (V2)
GOOGLE_MAPS_API_KEY=              # OPTIONAL  (V2)
S3_ENDPOINT=                      # OPTIONAL  (V2)
S3_ACCESS_KEY_ID=                 # OPTIONAL  (V2)
S3_SECRET_ACCESS_KEY=             # OPTIONAL  (V2)
S3_BUCKET=                        # OPTIONAL  (V2)
