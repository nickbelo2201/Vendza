{
  "name": "@vendza/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "prisma generate --watch --config ./prisma.config.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --config ./prisma.config.ts",
    "db:migrate": "prisma migrate dev --config ./prisma.config.ts",
    "db:push": "prisma db push --config ./prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --config ./prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
