{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "generated/**/*.ts"
  ]
}
