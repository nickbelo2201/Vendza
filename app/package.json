{
  "name": "vendza-app",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @vendza/api dev",
    "dev:web-client": "pnpm --filter @vendza/web-client dev",
    "dev:web-partner": "pnpm --filter @vendza/web-partner dev",
    "build": "turbo run build --concurrency=1",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @vendza/database db:generate",
    "db:migrate": "pnpm --filter @vendza/database db:migrate",
    "db:push": "pnpm --filter @vendza/database db:push",
    "db:seed": "pnpm --filter @vendza/database db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "sharp"
    ]
  }
}
